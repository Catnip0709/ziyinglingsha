/* pages/index/index.wxss */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
}

/* 背景图区域 */
.hero-section {
  position: relative;
  height: 45vh;
  width: 100%;
  overflow: hidden;
}

.hero-bg {
  width: 100%;
  height: 100%;
  background-color: #2d2d44;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(26, 26, 46, 0.3) 0%, rgba(26, 26, 46, 0.8) 100%);
}

.hero-content {
  position: absolute;
  bottom: 60rpx;
  left: 40rpx;
  z-index: 10;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
  margin-bottom: 16rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 4rpx;
}

/* 模块区域 */
.modules-container {
  flex: 1;
  padding: 40rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  align-content: start;
}

.module-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  opacity: 0;
  transform: translateY(80rpx);
  transition: all 0.3s ease;
}

.module-card:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.12);
}

.module-card.animate-in {
  animation: floatUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes floatUp {
  0% {
    opacity: 0;
    transform: translateY(80rpx) scale(0.9);
  }
  60% {
    transform: translateY(-10rpx) scale(1.02);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.module-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.story-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.official-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.fanart-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.aigc-icon {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.icon-text {
  font-size: 48rpx;
}

.module-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.module-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}